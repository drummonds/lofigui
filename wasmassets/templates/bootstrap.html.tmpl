<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
  <meta http-equiv="Pragma" content="no-cache">
  <meta http-equiv="Expires" content="0">
  <title>{{.Title}}</title>
  <link rel="stylesheet" href="./bulma.min.css">
</head>
<body>
  <section class="section">
    <div class="container">
      <h1 class="title">{{.Title}}</h1>
      <h2 class="subtitle">Go net/http handlers running in WASM inside a service worker</h2>
      <p id="buildstamp" class="has-text-grey is-size-7"></p>
      <div id="status">
        <progress class="progress is-primary" max="100">Loading...</progress>
        <p class="mt-3">Registering service worker...</p>
      </div>
      <pre id="log" class="mt-4" style="font-size:0.75em; max-height:400px; overflow-y:auto; background:#1a1a2e; color:#e0e0e0; padding:1em; border-radius:6px; display:none;"></pre>
    </div>
  </section>
  <script>
    var BUILD_DATE = {{printf "%q" .BuildDate}};
    var BUILD_VERSION = {{printf "%q" .BuildVersion}};
    var BOOT_ISO = new Date().toISOString();
    document.getElementById('buildstamp').textContent =
      'build ' + BUILD_DATE + ' — loaded ' + BOOT_ISO;
    function ts() { return new Date().toISOString().substr(11, 12); }
    console.log('[sw-boot] ' + ts() + ' ' + BUILD_VERSION + ' — loaded ' + BOOT_ISO);
    var DEBUG = /(?:^|[?&])debug=1(?:&|$)/.test(location.search);

    var statusDiv = document.getElementById('status');
    var statusP = statusDiv.querySelector('p');
    var logEl = document.getElementById('log');

    function clog(msg) { console.log('[sw-boot] ' + ts() + ' ' + msg); }

    var vlog = function() {};
    if (DEBUG) {
      logEl.style.display = '';
      vlog = function(msg) {
        clog(msg);
        logEl.textContent += ts() + ' ' + msg + '\n';
        logEl.scrollTop = logEl.scrollHeight;
      };
      navigator.serviceWorker.addEventListener('message', function(e) {
        if (e.data && e.data.type === 'swlog') vlog('SW: ' + e.data.msg);
      });
    }

    function status(msg) { statusP.textContent = msg; clog('STATUS: ' + msg); vlog('STATUS: ' + msg); }

    function showError(msg) {
      clog('ERROR: ' + msg);
      statusDiv.innerHTML = '<div class="notification is-danger">' +
        '<p><strong>Failed to start:</strong> ' + msg + '</p>' +
        '<p class="mt-2">Try a hard reload (Ctrl+Shift+R) or clear site data in DevTools.</p>' +
        '</div>';
    }

    function waitForWasm(startedAt) {
      var elapsed = Date.now() - startedAt;
      if (elapsed > 15000) {
        showError('WASM did not become ready within 15s (likely a stale service worker — try hard reload).');
        return;
      }
      fetch('./favicon.ico', {cache: 'no-store'})
        .then(function(resp) {
          if (resp.ok) { clog('WASM ready (' + elapsed + 'ms) — redirecting to ./'); window.location.replace('./'); }
          else { setTimeout(function() { waitForWasm(startedAt); }, 500); }
        })
        .catch(function() { setTimeout(function() { waitForWasm(startedAt); }, 500); });
    }

    if (!('serviceWorker' in navigator)) {
      showError('Service workers are not supported in this browser.');
    } else {
      clog('page URL: ' + location.href);

      navigator.serviceWorker.getRegistrations()
        .then(function(regs) {
          clog('found ' + regs.length + ' existing registration(s)');
          return Promise.all(regs.map(function(r) { return r.unregister(); }));
        })
        .then(function() {
          status('Loading WASM binary...');
          return navigator.serviceWorker.register('sw.js', {updateViaCache: 'none'});
        })
        .then(function(reg) {
          clog('register() resolved — scope=' + reg.scope);
          var w = reg.installing || reg.waiting || reg.active;
          if (w) {
            clog('worker state=' + w.state + ' script=' + w.scriptURL);
            w.addEventListener('statechange', function() {
              clog('worker statechange → ' + w.state);
              if (w.state === 'redundant') {
                showError('Service worker became redundant during install. Check DevTools → Debugger → ' + w.scriptURL + ' for the script error.');
              }
            });
          }
          return navigator.serviceWorker.ready;
        })
        .then(function(reg) {
          clog('ready resolved — scope=' + reg.scope);
          if (navigator.serviceWorker.controller) return;
          clog('waiting for controllerchange...');
          return new Promise(function(resolve) {
            var timer = setTimeout(resolve, 2000);
            navigator.serviceWorker.addEventListener('controllerchange', function() {
              clearTimeout(timer); resolve();
            }, {once: true});
          });
        })
        .then(function() {
          status('Compiling WASM binary...');
          clog('controller: ' + (navigator.serviceWorker.controller ? navigator.serviceWorker.controller.scriptURL : 'none'));
          waitForWasm(Date.now());
        })
        .catch(function(err) { showError(err.message || String(err)); });
    }
  </script>
</body>
</html>
